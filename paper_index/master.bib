  title = {Correction to “Coarse-Grained Model of Disordered RNA for Simulations of Biomolecular Condensates”},
  author = {Ikki Yasuda, Sören von Bülow, Giulio Tesei, Eiji Yamamoto, Kenji Yasuoka, Kresten Lindorff-Larsen},
