@article{matthews_chromatin_2019,
	title = {Chromatin {Architecture} in the {Fly}: {Living} without {CTCF}/{Cohesin} {Loop} {Extrusion}?: {Alternating} {Chromatin} {States} {Provide} a {Basis} for {Domain} {Architecture} in \textit{{Drosophila}}},
