	pages = {991--1000},
	file = {PDF:/Users/brandani/Zotero/storage/AZRGKSMX/Ramasamy et al. - 2023 - The Mediator complex regulates enhancer-promoter interactions.pdf:application/pdf},
}

@article{aljahani_analysis_2022,
	title = {Analysis of sub-kilobase chromatin topology reveals nano-scale regulatory interactions with variable dependence on cohesin and {CTCF}},
