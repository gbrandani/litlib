@article{nandymazumdar_looping_2020,
	title = {Looping of upstream cis-regulatory elements is required for {CFTR} expression in human airway epithelial cells},
	volume = {48},
	copyright = {http://creativecommons.org/licenses/by-nc/4.0/},
	issn = {0305-1048, 1362-4962},
	url = {https://academic.oup.com/nar/article/48/7/3513/5755883},
	doi = {10.1093/nar/gkaa089},
	abstract = {The CFTR gene lies within an invariant topologically associated domain (TAD) demarcated by CTCF and cohesin, but shows cell-type speciﬁc control mechanisms utilizing different cis-regulatory elements (CRE) within the TAD. Within the respiratory epithelium, more than one cell type expresses CFTR and the molecular mechanisms controlling its transcription are likely divergent between them. Here, we determine how two extragenic CREs that are prominent in epithelial cells in the lung, regulate expression of the gene. We showed earlier that these CREs, located at −44 and −35 kb upstream of the promoter, have strong cell-type-selective enhancer function. They are also responsive to inﬂammatory mediators and to oxidative stress, consistent with a key role in CF lung disease. Here, we use CRISPR/Cas9 technology to remove these CREs from the endogenous locus in human bronchial epithelial cells. Loss of either site extinguished CFTR expression and abolished longrange interactions between these sites and the gene promoter, suggesting non-redundant enhancers. The deletions also greatly reduced promoter interactions with the 5′ TAD boundary. We show substantial recruitment of RNAPII to the −35 kb element and identify CEBP as a key activator of airway expression of CFTR, likely through occupancy at this CRE and the gene promoter.},
	language = {en},
	number = {7},
	urldate = {2026-04-01},
	journal = {Nucleic Acids Research},
	author = {NandyMazumdar, Monali and Yin, Shiyi and Paranjapye, Alekh and Kerschner, Jenny L and Swahn, Hannah and Ge, Alex and Leir, Shih-Hsing and Harris, Ann},
	month = apr,
	year = {2020},
	pages = {3513--3524},
	file = {PDF:/Users/brandani/Zotero/storage/4ZPXTGYB/NandyMazumdar et al. - 2020 - Looping of upstream cis-regulatory elements is required for CFTR expression in human airway epitheli.pdf:application/pdf},
}

