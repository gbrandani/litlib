	pages = {491--506.e28},
	file = {PDF:/Users/brandani/Zotero/storage/QLPA62CW/Li et al. - 2019 - Single-Molecule Nanoscopy Elucidates RNA Polymerase II Transcription at Single Genes in Live Cells.pdf:application/pdf},
