	journal = {The EMBO Journal},
	author = {Martínez‐García, Belén and Dyson, Sílvia and Segura, Joana and Ayats, Alba and Cutts, Erin E and Gutierrez‐Escribano, Pilar and Aragón, Luís and Roca, Joaquim},
