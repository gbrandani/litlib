@article{zhu_model_2021,
	title = {A model of active transcription hubs that unifies the roles of active promoters and enhancers},
	volume = {49},
	issn = {0305-1048, 1362-4962},
	url = {https://academic.oup.com/nar/article/49/8/4493/6238408},
	doi = {10.1093/nar/gkab235},
	abstract = {An essential questions of gene regulation is how large number of enhancers and promoters organize into gene regulatory loops. Using transcriptionfactor binding enrichment as an indicator of enhancer strength, we identiﬁed a portion of H3K27ac peaks as potentially strong enhancers and found a universal pattern of promoter and enhancer distribution: At actively transcribed regions of length of ∼200–300 kb, the numbers of active promoters and enhancers are inversely related. Enhancer clusters are associated with isolated active promoters, regardless of the gene’s cell-type speciﬁcity. As the number of nearby active promoters increases, the number of enhancers decreases. At regions where multiple active genes are closely located, there are few distant enhancers. With Hi-C analysis, we demonstrate that the interactions among the regulatory elements (active promoters and enhancers) occur predominantly in clusters and multiway among linearly close elements and the distance between adjacent elements shows a preference of ∼30 kb. We propose a simple rule of spatial organization of active promoters and enhancers: Gene transcriptions and regulations mainly occur at local active transcription hubs contributed dynamically by multiple elements from linearly close enhancers and/or active promoters. The hub model can be represented with a ﬂowershaped structure and implies an enhancer-like role of active promoters.},
	language = {en},
	number = {8},
	urldate = {2026-04-01},
	journal = {Nucleic Acids Research},
	author = {Zhu, Iris and Song, Wei and Ovcharenko, Ivan and Landsman, David},
	month = may,
	year = {2021},
	pages = {4493--4505},
	file = {PDF:/Users/brandani/Zotero/storage/5THTI6AP/Zhu et al. - 2021 - A model of active transcription hubs that unifies the roles of active promoters and enhancers.pdf:application/pdf},
}

@article{lando_enhancer-promoter_2024,
	title = {Enhancer-promoter interactions are reconfigured through the formation of long-range multiway hubs as mouse {ES} cells exit pluripotency},
