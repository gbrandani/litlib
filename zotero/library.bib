	pages = {2139},
	file = {PDF:/Users/brandani/Zotero/storage/LR6IKXUZ/Aljahani et al. - 2022 - Analysis of sub-kilobase chromatin topology reveals nano-scale regulatory interactions with variable.pdf:application/pdf},
}

